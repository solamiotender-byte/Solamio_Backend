### 21. Create Performa Invoice with Cess
POST {{baseURL}}/finance/sales/performa-invoices
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "companyId": "{{companyId}}",
  "clientId": "{{clientId}}",
  "performaInvoiceTitle": "Product with Cess",
  "performaInvoiceNumber": "PI-2025-0004",
  "date": "2025-01-15T00:00:00.000Z",
  "dueDate": "2025-02-15T00:00:00.000Z",
  "taxType": "exclusive",
  "items": [
    {
      "name": "Luxury Item",
      "hsn": "998313",
      "unit": "Piece",
      "quantity": 1,
      "rate": 50000,
      "taxType": "cgst_sgst",
      "taxRate": 28,
      "cess": [
        {
          "name": "Luxury Cess",
          "rate": 1
        }
      ]
