}

### 22. Try to update accepted performa invoice (should fail)
PUT {{baseURL}}/finance/sales/performa-invoices/{{performaInvoiceId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "performaInvoiceTitle": "This should fail if status is accepted"
}

### 23. Try invalid status transition (should fail)
PATCH {{baseURL}}/finance/sales/performa-invoices/{{performaInvoiceId}}/status
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "status": "draft"
}

### 24. Delete Draft Performa Invoice
DELETE {{baseURL}}/finance/sales/performa-invoices/{{performaInvoiceId}}
Authorization: Bearer {{authToken}}

### 25. Create Performa Invoice from Quotation
POST {{baseURL}}/finance/sales/performa-invoices
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "companyId": "{{companyId}}",
  "clientId": "{{clientId}}",
  "quotationId": "YOUR_QUOTATION_ID_HERE",
  "convertedFromQuotation": true,
  "performaInvoiceTitle": "Converted from Quotation",
  "performaInvoiceNumber": "PI-2025-0005",
  "date": "2025-01-15T00:00:00.000Z",
  "dueDate": "2025-02-15T00:00:00.000Z",
  "items": [
    {
      "name": "Service from Quotation",
      "quantity": 1,
      "rate": 5000,
      "taxType": "cgst_sgst",
      "taxRate": 18
    }
  ]
}

### Error Test Cases

### 26. Create with invalid data (should fail)
POST {{baseURL}}/finance/sales/performa-invoices
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "companyId": "invalid-id",
  "performaInvoiceTitle": "",
  "date": "invalid-date"
}

### 27. Get non-existent performa invoice (should return 404)
GET {{baseURL}}/finance/sales/performa-invoices/507f1f77bcf86cd799439011
Authorization: Bearer {{authToken}}

### 28. Update non-existent performa invoice (should return 404)
PUT {{baseURL}}/finance/sales/performa-invoices/507f1f77bcf86cd799439011
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "performaInvoiceTitle": "Non-existent"
}

### 29. Record payment without authorization (should fail)
POST {{baseURL}}/finance/sales/performa-invoices/{{performaInvoiceId}}/record-payment
Content-Type: application/json

{
  "paymentAmount": 1000,
  "paymentMethod": "cash"
}