}

### Get All Items
GET {{url}}/getAllItems/{{companyId}}
Authorization: Bearer {{token}}

### Get Item Details
GET {{url}}/itemDetails/{{companyId}}/{{itemId}}
Authorization: Bearer {{token}}

### Update Item
PUT {{url}}/updateItem/{{companyId}}/{{itemId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated Product Name"
}

### Delete Item
DELETE {{url}}/deleteItem/{{companyId}}/{{itemId}}
Authorization: Bearer {{token}}

### Bulk Delete Items
DELETE {{url}}/bulkDeleteItems/{{companyId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "itemIds": ["{{itemId1}}", "{{itemId2}}"]
}

### Update Stock
PUT {{url}}/updateStock/{{companyId}}/{{itemId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "adjustment": 10,
  "adjustmentType": "increase",
  "reason": "Restock"
}

### Get Low Stock Items
GET {{url}}/lowStockItems/{{companyId}}
Authorization: Bearer {{token}}

### Get Items by Category
GET {{url}}/itemsByCategory/{{companyId}}/{{categoryId}}
Authorization: Bearer {{token}}

### Search Items
GET {{url}}/searchItems/{{companyId}}?q=Test
Authorization: Bearer {{token}}

### Get Item Statistics
GET {{url}}/statistics/{{companyId}}
Authorization: Bearer {{token}}

### Upload Item Image
POST {{url}}/uploadImage/{{itemId}}
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

--boundary
Content-Disposition: form-data; name="image"; filename="test.jpg"
Content-Type: image/jpeg

< ./test.jpg
--boundary--

### Delete Item Image
DELETE {{url}}/deleteImage/{{itemId}}
Authorization: Bearer {{token}}